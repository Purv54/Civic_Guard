# ═══════════════════════════════════════════════════════════════
#  Civic Guard — .gitignore
#  Django (backend) + React/Vite (frontend) + Python venv
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
#  🔐 SECRETS — NEVER COMMIT THESE
# ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
Civic_Guard/.env
Civic_Guard/.env.local

# Keep the example template (no real credentials inside)
!.env.example
!Civic_Guard/.env.example


# ───────────────────────────────────────────────────────────────
#  🐍 Python / Django (backend)
# ───────────────────────────────────────────────────────────────

# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environment
venv/
.venv/
env/
ENV/
.env/

# Django sensitive/generated files
Civic_Guard/db.sqlite3
db.sqlite3

# Uploaded user files (runtime data, not source)
Civic_Guard/media/
media/

# Collected static files (regenerated by collectstatic)
Civic_Guard/staticfiles/
staticfiles/

# Django migrations — keep these, they are part of source
# (do NOT add migrations/ here)

# Django local settings override (if you use one)
local_settings.py
Civic_Guard/Civic_Guard/local_settings.py

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# PyInstaller
*.manifest
*.spec

# Testing
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/


# ───────────────────────────────────────────────────────────────
#  ⚛️  React / Node.js / Vite (frontend)
# ───────────────────────────────────────────────────────────────

# Dependencies (huge — always regenerated by npm install)
frontend/node_modules/
node_modules/

# Build output (regenerated by npm run build)
frontend/dist/
frontend/build/
dist/
build/

# Vite cache
frontend/.vite/
.vite/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# npm / yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lock files — keep one of these (whichever your team uses)
# If using npm  → keep package-lock.json, ignore yarn.lock
# If using yarn → keep yarn.lock, ignore package-lock.json
# Uncomment the one you DON'T use:
# yarn.lock
# package-lock.json


# ───────────────────────────────────────────────────────────────
#  💻 IDE & Editor
# ───────────────────────────────────────────────────────────────

# VS Code — keep workspace settings, ignore user-specific ones
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*


# ───────────────────────────────────────────────────────────────
#  🖥️  Operating System
# ───────────────────────────────────────────────────────────────

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~


# ───────────────────────────────────────────────────────────────
#  📦 Misc
# ───────────────────────────────────────────────────────────────

# Logs
*.log
logs/

# Temp / scratch files (our debug helpers)
_check_users.py
test_api.py
generate_test_data.py
dummy.jpg

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# Celery
celerybeat-schedule
celerybeat.pid

# AWS / deployment
.elasticbeanstalk/
.aws/
