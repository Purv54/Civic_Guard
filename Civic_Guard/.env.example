# ════════════════════════════════════════════════════════════
#  Civic Guard — Environment Variables
#  !! DO NOT COMMIT THIS FILE TO VERSION CONTROL !!
#  Add .env to your .gitignore
# ════════════════════════════════════════════════════════════

# ─── Django ───────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-django-key-here
DEBUG=True

# ─── SMTP / Email ─────────────────────────────────────────
# Leave EMAIL_HOST_USER blank to use the console backend (dev mode).
# Fill in all values below for real email sending.

# --- Gmail (recommended) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=ranpariyapurv@gmail.com
EMAIL_HOST_PASSWORD=mvnayrjxpnmbgair
# NOTE: Use a Gmail "App Password", NOT your normal account password.
# Enable 2FA → https://myaccount.google.com/apppasswords

# --- Outlook / Hotmail (alternative) ---
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-outlook-password

# ─── Display name shown in email client ───────────────────
DEFAULT_FROM_EMAIL=Civic Guard <ranpariyapurv@gmail.com>

# ─── AI / FastAPI microservice ────────────────────────────
FASTAPI_AI_SERVICE_URL=http://127.0.0.1:8001
